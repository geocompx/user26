// VS Code Dev Container for the useR! 2026 "Geocomputation with R" tutorial.
// Uses ghcr.io/geocompx/qgis, which bundles R, RStudio, Quarto and the full
// geocompx spatial stack (sf, terra, tmap, spData, spDataLarge, leaflet, ...)
// as well as GIS software suites. Find more geocompr images at
// https://github.com/geocompx/docker.
//
// The image is amd64-only; on Apple Silicon OrbStack runs it under Rosetta.
// VS Code UI stays native; only R runs in the container.
//
// Usage: Cmd+Shift+P -> `Dev Containers: Reopen in Container`.
{
  "name": "geocompr-user26",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--platform", "linux/amd64",
    "-p", "8787:8787", "-e ROOT=true", "-e DISABLE_AUTH=true"
  ],
  "remoteUser": "rstudio",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/rstudio/user26,type=bind",
  "workspaceFolder": "/home/rstudio/user26",
  "containerEnv": {
    "XDG_RUNTIME_DIR": "/tmp/runtime-rstudio"
  },
  // installs required R watcher packages and configures VS Code session startup
  "postCreateCommand": "bash .devcontainer/init-httpgd.sh --install",
  // re-applies the startup hook if the home profile was reset
  "postStartCommand": "bash .devcontainer/init-httpgd.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "reditorsupport.r",
        "rdebugger.r-debugger",
        "quarto.quarto"
      ],
      "settings": {
        "r.rpath.linux": "/usr/local/bin/R",
        "r.rterm.linux": "/usr/local/bin/R",
        "r.bracketedPaste": true,
        "r.sessionWatcher": true,
        "r.plot.useHttpgd": false,
        "r.session.viewers.viewColumn": {
          "plot": "Beside",
          "browser": "Active",
          "viewer": "Two",
          "pageViewer": "Active",
          "view": "Two",
          "helpPanel": "Two"
        },
        "[r]": {
          "editor.formatOnSave": true,
          "editor.formatOnPaste": true
        },
        "[quarto]": {
          "editor.formatOnSave": true
        },
        "editor.rulers": [80],
        "editor.tabSize": 2,
        "editor.wordWrap": "on",
        "editor.minimap.enabled": false,
        "files.trimTrailingWhitespace": true
      }
    }
  }
}
